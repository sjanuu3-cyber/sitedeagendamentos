{
  "name": "multi-tenant-scheduler",
  "version": "1.0.0",
  "description": "Sistema de agendamento multiempresa com Node.js, Express e MySQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "node src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart multi-tenant-scheduler",
    "pm2:stop": "pm2 stop multi-tenant-scheduler",
    "db:schema:info": "node -e \"console.log('Execute backend/src/db/schema.sql no seu MySQL ou phpMyAdmin.')\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
